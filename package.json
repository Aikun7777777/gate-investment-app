{
  "name": "gate-investment-app",
  "version": "1.0.0",
  "description": "Gate.io 投资辅助桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "python:server": "python3 python/gate_api_server.py"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.gate.investment",
    "productName": "Gate投资助手",
    "mac": {
      "category": "public.app-category.finance"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "python/**/*"
    ]
  }
}
